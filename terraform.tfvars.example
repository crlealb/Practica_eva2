# Ejemplo de personalización: copia este archivo a terraform.tfvars y reemplaza los valores.

aws_region = "us-east-1"

# Módulos locales para esta evaluación.
networking_source = "./modules/networking"
compute_source    = "./modules/compute"
storage_source    = "./modules/storage"

# Nombres y prefijos legibles en español.
vpc_name      = "red-empresa"
bucket_prefix = "app-bucket"
bucket_name   = "bucket-aplicacion"
instance_name = "servidor-web"
instance_type = "t3.micro"
ami           = "ami-0c02fb55956c7d316"

tags = {
  Environment = "desarrollo"
  Owner       = "equipo-infra"
}
